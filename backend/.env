# ─── Firebase / Google Cloud ───────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=papertrail-e7ac6.appspot.com

# ─── OCR ────────────────────────────────────────────────────────────────────────
GOOGLE_VISION_ENABLED=false          # Set to false to use Tesseract instead
OCR_UNCERTAINTY_THRESHOLD=0.75

# ─── Template Matching ──────────────────────────────────────────────────────────
MATCH_CONFIDENCE_THRESHOLD=0.80

# ─── Session ────────────────────────────────────────────────────────────────────
SESSION_EXPIRY_HOURS=2

# ─── Voice & Accessibility Layer ────────────────────────────────────────────────
# TODO: Ask teammate for the ANTHROPIC_API_KEY and paste it here
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama
VOICE_AGENT_MODEL=deepseek-r1:1.5b
