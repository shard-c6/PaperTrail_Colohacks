# ─── Firebase / Google Cloud ───────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=papertrail-e7ac6.appspot.com

# ─── OCR ────────────────────────────────────────────────────────────────────────
GOOGLE_VISION_ENABLED=true          # Set to false to use Tesseract instead
OCR_UNCERTAINTY_THRESHOLD=0.75

# ─── Template Matching ──────────────────────────────────────────────────────────
MATCH_CONFIDENCE_THRESHOLD=0.80

# ─── Session ────────────────────────────────────────────────────────────────────
SESSION_EXPIRY_HOURS=2

# ─── Voice & Accessibility Layer (Ollama — local model) ─────────────────────────
# Run: ollama serve   (starts the local API server on port 11434)
# Pull the model first: ollama pull deepseek-r1:1.5b
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama                     # Ollama ignores this value; any string works
VOICE_AGENT_MODEL=deepseek-r1:1.5b       # Change to any model you have pulled locally
